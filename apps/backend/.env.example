# ------------------------------------------------------------------------------
# Backend Environment Configuration
# Copy file này thành .env và điền các giá trị phù hợp
# ------------------------------------------------------------------------------

# Chế độ chạy: "mock" (không cần Neo4j) hoặc "graphrag" (retrieval thật)
APP_MODE=mock

# ==============================================================================
# GraphRAG Mode Settings (Chỉ cần thiết khi APP_MODE=graphrag)
# ==============================================================================

# Neo4j Database
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Async API boundary cho retrieval runtime đồng bộ
BACKEND_RETRIEVAL_TIMEOUT_SECONDS=30
BACKEND_RETRIEVAL_MAX_CONCURRENCY=4
BACKEND_RETRIEVAL_SHUTDOWN_GRACE_SECONDS=5

# LLM Provider (gemini | deepseek | openai | ollama)
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# API Keys cho các Provider
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Cấu hình Ollama local (nếu dùng ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ==============================================================================
# Server Settings
# ==============================================================================

# Danh sách URL được phép gọi API (phân cách bằng dấu phẩy)
CORS_ORIGINS=["http://localhost:3000"]
