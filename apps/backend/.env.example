# ------------------------------------------------------------------------------
# Backend Environment Configuration
# Copy file này thành .env và điền các giá trị phù hợp
# ------------------------------------------------------------------------------

# Chế độ chạy: "mock" (không cần Neo4j) hoặc "graphrag" (retrieval thật)
APP_MODE=mock

# ==============================================================================
# GraphRAG Mode Settings (Chỉ cần thiết khi APP_MODE=graphrag)
# ==============================================================================

# Neo4j Database
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Async API boundary cho retrieval runtime đồng bộ
BACKEND_RETRIEVAL_TIMEOUT_SECONDS=30
BACKEND_RETRIEVAL_MAX_CONCURRENCY=4
BACKEND_RETRIEVAL_SHUTDOWN_GRACE_SECONDS=5

# Answer generation là opt-in; retrieval-only vẫn chạy khi false
ANSWER_GENERATION_ENABLED=false
ANSWER_PROVIDER=gemini
ANSWER_MODEL=gemini-3.5-flash
ANSWER_TIMEOUT_SECONDS=45
ANSWER_MAX_CONCURRENCY=2
ANSWER_MAX_RETRIES=2
ANSWER_MAX_OUTPUT_TOKENS=2048
ANSWER_TEMPERATURE=0
ANSWER_CONTEXT_MAX_CHARS=24000
ANSWER_HISTORY_MAX_MESSAGES=6
ANSWER_HISTORY_MAX_CHARS=4000
ANSWER_STREAM_CHUNK_CHARS=160

# Legacy/mock LLM provider settings
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# API Keys cho các Provider
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Cấu hình Ollama local (nếu dùng ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ==============================================================================
# Server Settings
# ==============================================================================

# Danh sách URL được phép gọi API (phân cách bằng dấu phẩy)
CORS_ORIGINS=["http://localhost:3000"]
